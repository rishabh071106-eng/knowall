# Copy this file to backend/.env and fill in the values.

# --- server ---
PORT=4000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-string
CORS_ORIGIN=http://localhost:5173

# --- postgres ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/knowall

# --- AWS ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=knowall-videos
S3_UPLOAD_PREFIX=uploads/

# --- CloudFront signed URLs ---
CLOUDFRONT_DOMAIN=dxxxxxxxxxxxxx.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=KXXXXXXXXXXXXX
# Paste the full PEM contents on one line with \n for newlines,
# OR set CLOUDFRONT_PRIVATE_KEY_PATH to a file path instead.
CLOUDFRONT_PRIVATE_KEY=
CLOUDFRONT_PRIVATE_KEY_PATH=

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- frontend public key (exposed to browser) ---
# Also put this in frontend/.env as VITE_RAZORPAY_KEY_ID
